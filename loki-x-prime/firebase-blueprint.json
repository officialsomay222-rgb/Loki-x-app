{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A chat conversation session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["id", "title", "updatedAt", "uid"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "sent", "error"] },
        "isImage": { "type": "boolean" },
        "audioUrl": { "type": "string" },
        "isVoiceResponse": { "type": "boolean" }
      },
      "required": ["id", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/users/{uid}/sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Chat sessions for a specific user"
    },
    "/users/{uid}/sessions/{sessionId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat session"
    }
  }
}
